generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String          @id @default(cuid())
  clerkUserId   String          @unique
  MemberID      String?         @unique
  name          String?
  email         String          @unique
  image         String?
  role          Role            @default(MEMBER)
  phone         String?
  dob           DateTime?
  gender        String?
  location      String?
  weight        String?
  heightFeet    String?
  heightInches  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  posts         Post[]
  votes         Vote[]
  classBookings ClassBookings[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  votes     Vote[]
}

model Vote {
  id     String   @id @default(cuid())
  type   VoteType
  userId String
  postId String
  post   Post     @relation(fields: [postId], references: [id])
  user   User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}



/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Classes {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  classname  String?
  trainer    String?
  duration   String?
  class_fees Int?
  class_time String?
  class_days String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Trainers {
  id            BigInt   @id @default(autoincrement())
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  name          String?
  role          String?
  fee_per_week  Int?
  fee_per_month Int?
  trainer_time  String?
}

model ClassBookings {
  id          Int       @id @default(autoincrement())
  clerkUserId String
  user        User      @relation(fields: [clerkUserId], references: [clerkUserId])
  classId     Int
  name        String?
  className   String?
  bookingDate DateTime  @db.Timestamp(6)
  validTill   DateTime? @db.Timestamp(6)
  status      String?   @default("CONFIRMED")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model TrainerBookings {
  id          Int     @id @default(autoincrement())
  clerkUserId String
  MemberID    String?
  trainerId   Int
  trainerName String?
  timeSlot    String
  plan        String?
  pricing     Int?
}

model Memberships {
  id         Int       @id @default(autoincrement())
  name       String
  price      Int
  period     String?   @default("/month")
  features   String[]
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model Payments {
  id            Int       @id @default(autoincrement())
  clerkUserId   String
  amount        Int
  transactionId String    @unique
  bookingType   String
  referenceId   Int
  status        String?   @default("PENDING")
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
}

model MembershipBookings {
  id          Int       @id @default(autoincrement())
  clerkUserId String
  MemberID    String?
  name        String?
  plan        String?
  price       Int?
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  status      String?   @default("ACTIVE")
}

enum VoteType {
  UP
  DOWN
}

enum Role {
  MEMBER
  ADMIN
  TRAINER
}

enum Plan {
  BASIC
  STANDARD
  PREMIUM
}
